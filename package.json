{
  "name": "boc-exchange-rates-addin",
  "version": "1.0.0",
  "description": "Bank of Canada Exchange Rate Tools for Excel",
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "dev:certs": "office-addin-dev-certs install",
    "dev:server": "webpack serve --mode development",
    "make:prod-manifest": "node scripts/make-prod-manifest.js",
    "make:github-manifest": "node scripts/make-prod-manifest.js https://lilainx.github.io/BOC-Tool",
    "validate": "office-addin-manifest validate manifest.xml"
  },
  "dependencies": {
    "@microsoft/office-js": "^1.1.0"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.0",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "office-addin-debugging": "^6.1.1",
    "office-addin-manifest": "^2.1.5",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.5.0",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0"
  }
}
